# ScholarNova local-development configuration.
# Copy this file to backend/.env. Never commit backend/.env.

APP_NAME=ScholarNova
APP_ENV=development
DEBUG=true
SECRET_KEY=replace-with-a-long-random-value

# Zero-setup local database. Tables are created automatically at startup.
DATABASE_URL=sqlite+aiosqlite:///./scholarnova.db

# Leave empty to use the built-in in-memory cache.
REDIS_URL=

# Default OpenAI-compatible LLM.
# MiMo example:
# OPENAI_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
# OPENAI_DEFAULT_MODEL=mimo-v2.5-pro
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o
DEFAULT_LLM_PROVIDER=openai

# Optional alternative providers.
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:14b

# Optional SenseNova image/diagram generation.
SENSENOVA_API_KEY=
SENSENOVA_API_BASE=https://token.sensenova.cn/v1
SENSENOVA_DEFAULT_MODEL=sensenova-u1-fast

# Academic sources. Semantic Scholar works without a key at a lower shared rate.
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_EMAIL=
OPENALEX_API_KEY=
CROSSREF_EMAIL=

# Optional official benchmark access.
HF_ACCESS_TOKEN=
HF_TOKEN=

CORS_ORIGINS=["http://localhost:5173"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]
LOG_LEVEL=INFO
LOG_FORMAT=json
