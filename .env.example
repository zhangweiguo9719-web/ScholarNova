# ScholarNova Docker deployment configuration.
# Copy this file to .env and replace all passwords and keys before deployment.

# =============================================================================
# 应用配置
# =============================================================================
APP_NAME=ScholarNova
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# =============================================================================
# 数据库配置 (PostgreSQL)
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=scholar
POSTGRES_PASSWORD=scholar_password
POSTGRES_DB=scholar_agent

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# LLM 模型配置
# =============================================================================
# OpenAI
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# 本地模型 (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:14b

# 默认 LLM 提供商: openai | anthropic | ollama
DEFAULT_LLM_PROVIDER=openai

# SenseNova (商汤)
SENSENOVA_API_KEY=
SENSENOVA_API_BASE=https://token.sensenova.cn/v1
SENSENOVA_DEFAULT_MODEL=sensenova-u1-fast

# =============================================================================
# 学术数据源 API Keys
# =============================================================================
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_EMAIL=
CROSSREF_EMAIL=
HF_ACCESS_TOKEN=
HF_TOKEN=

# =============================================================================
# 前端配置
# =============================================================================
VITE_API_BASE_URL=http://localhost:8000

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# CORS 配置
# =============================================================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# =============================================================================
# 安全配置
# =============================================================================

# 允许的主机名（逗号分隔）
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# 速率限制（每 IP 每分钟）
RATE_LIMIT_SEARCH_PER_MINUTE=30
RATE_LIMIT_ANALYSIS_PER_MINUTE=10

# 最大请求体大小（bytes，默认 10MB）
MAX_REQUEST_SIZE=10485760

# SSRF 防护
# 是否允许访问内网 IP（生产环境必须为 false）
ALLOW_PRIVATE_IPS=false
# 是否允许 HTTP 协议（非 HTTPS，生产环境必须为 false）
ALLOW_HTTP=false

# LLM 请求安全
# LLM 请求超时（秒）
LLM_REQUEST_TIMEOUT=30
# LLM 响应最大大小（bytes，默认 10MB）
LLM_MAX_RESPONSE_SIZE=10485760
